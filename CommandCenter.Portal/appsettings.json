{
  /*
   * appsettings.json — CommanCenter Portal
   * Valores BASE compartidos por todos los ambientes.
   * Los archivos appsettings.Development.json / appsettings.Production.json
   * sobreescriben únicamente las claves que cambian por ambiente.
   */

  /* ── API Backend ──────────────────────────────────────────────────────────
   * BaseUrl        : URL raíz del API al que apunta el Portal.
   *                  DEV  → https://localhost:7001/
   *                  PROD → https://api.commanCenter.com/
   * TimeoutSeconds : Tiempo máximo de espera por respuesta del API (segundos).
   */
  "ApiSettings": {
    "BaseUrl": "https://api.CommanCenter.com/",
    "TimeoutSeconds": 30
  },

  /* ── Autenticación por Cookie ─────────────────────────────────────────────
   * CookieName    : Nombre de la cookie de sesión del Portal.
   * ExpireMinutes : Minutos de inactividad antes de expirar la sesión (480 = 8h).
   * LoginPath     : Ruta a la que redirige cuando el usuario no está autenticado.
   * LogoutPath    : Ruta del endpoint de cierre de sesión.
   */
  "Authentication": {
    "CookieName": "CommanCenter.Auth",
    "ExpireMinutes": 480,
    "LoginPath": "/Auth/Login",
    "LogoutPath": "/Auth/Logout"
  },

  /* ── Application Insights ─────────────────────────────────────────────────
   * Enabled          : Activar telemetría hacia Azure Application Insights.
   *                    DEV  → false  (no se factura ni contamina métricas)
   *                    PROD → true
   * ConnectionString : Connection string del recurso de Application Insights.
   *                    Se obtiene en Azure Portal → Application Insights → Overview.
   *                    En PROD se debe inyectar como variable de entorno o secret.
   */
  "ApplicationInsights": {
    "Enabled": false,
    "ConnectionString": ""
  },

  /* ── Serilog (logging estructurado) ──────────────────────────────────────
   * Default   : Nivel mínimo global de logs.
   *             DEV  → Debug   (ver trazas detalladas)
   *             PROD → Information
   * Override  : Silencia namespaces ruidosos de Microsoft y System.
   */
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },

  /* ── Logging nativo de ASP.NET Core ──────────────────────────────────────
   * Se mantiene alineado con Serilog para evitar logs duplicados.
   */
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  /* ── Azure Key Vault ─────────────────────────────────────────────────────
   * Enabled  : Activa la integración con Key Vault.
   *            DEV  → false (usar User Secrets o appsettings locales)
   *            PROD → true
   * VaultUri : URI del Key Vault en Azure.
   *            Formato: https://<nombre-vault>.vault.azure.net/
   *            Se autentica con DefaultAzureCredential (Managed Identity en PROD,
   *            Azure CLI / VS en DEV cuando Enabled=true).
   */
  "KeyVault": {
    "Enabled": false,
    "VaultUri": ""
  },

  /* ── Notification API ────────────────────────────────────────────────────
   * BaseUrl        : URL base de la Notification API (puede ir detrás del APIM).
   * TimeoutSeconds : Tiempo máximo de espera por respuesta.
   * ApiKey         : Clave de suscripción de APIM (Ocp-Apim-Subscription-Key).
   *                  En PROD dejar vacío aquí e inyectar desde Key Vault:
   *                  secret name → NotificationApi--ApiKey
   */
  "NotificationApi": {
    "BaseUrl": "",
    "TimeoutSeconds": 15,
    "ApiKey": ""
  },

  /* ── Hosts permitidos ────────────────────────────────────────────────────
   * "*" permite cualquier host (adecuado cuando hay proxy inverso/load balancer).
   * En PROD se puede restringir a: "portal.commanCenter.com"
   */
  "AllowedHosts": "*"
}
