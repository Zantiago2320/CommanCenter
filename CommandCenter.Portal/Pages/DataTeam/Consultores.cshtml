@page
@model CommanCenter.Portal.Pages.DataTeam.ConsultoresModel
@{
    ViewData["Title"] = "Consultores";
}

@section Styles {
    <style>
        .avatar-circle {
            width: 38px; height: 38px; border-radius: 50%;
            object-fit: cover; background: #6366f1;
            display: inline-flex; align-items: center; justify-content: center;
            color: #fff; font-weight: 700; font-size: .85rem;
        }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Consultores</h2>
    <div class="d-flex align-items-center gap-2">
        <span class="badge bg-primary fs-6">@Model.Consultores.Count registros</span>
        <a asp-page="/DataTeam/ConsultoresDeshabilitados" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-person-dash me-1"></i>Ver deshabilitados
        </a>
        <a asp-page="/DataTeam/CrearConsultor" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Consultor
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Success))
{
    <div class="alert alert-success">@Model.Success</div>
}

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

<form method="get" class="card shadow-sm mb-3">
    <div class="card-body d-flex flex-wrap align-items-end gap-2">
        <div>
            <label class="form-label small mb-1">Filtrar por célula</label>
            <select name="CelulaFiltro" class="form-select form-select-sm" style="min-width: 220px;">
                <option value="">Todas las células</option>
                @foreach (var cel in Model.Celulas)
                {
                    if (Model.CelulaFiltro == cel.Id)
                    {
                        <option value="@cel.Id" selected>@cel.Nombre</option>
                    }
                    else
                    {
                        <option value="@cel.Id">@cel.Nombre</option>
                    }
                }
            </select>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-funnel me-1"></i>Filtrar
        </button>
        @if (Model.CelulaFiltro.HasValue)
        {
            <a asp-page="/DataTeam/Consultores" class="btn btn-outline-secondary btn-sm">Limpiar</a>
        }
        <span class="ms-auto text-muted small align-self-center">
            <i class="bi bi-sort-down me-1"></i>Ordenados por fecha de creación (más recientes primero)
        </span>
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th></th>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Cargo</th>
                        <th>Tecnología</th>
                        <th>Seniority</th>
                        <th>Células</th>
                        <th>Estado</th>
                        <th>Creado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Consultores)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(c.FotoUrl))
                                {
                                    <img src="@c.FotoUrl" alt="@c.NombreCompleto" class="avatar-circle" />
                                }
                                else
                                {
                                    <span class="avatar-circle">@c.Nombre[0]@c.Apellido[0]</span>
                                }
                            </td>
                            <td class="fw-semibold">@c.NombreCompleto</td>
                            <td class="text-muted small">@c.Email</td>
                            <td>@(c.Cargo ?? "—")</td>
                            <td>@(c.Tecnologia ?? "—")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(c.NivelSeniority))
                                {
                                    <span class="badge bg-secondary">@c.NivelSeniority</span>
                                }
                            </td>
                            <td>
                                @if (c.Celulas.Count > 0)
                                {
                                    @foreach (var cel in c.Celulas)
                                    {
                                        <span class="badge bg-info text-dark me-1 mb-1">@cel</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (c.Habilitado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary" title="@c.MotivoDeshabilitacion">Inactivo</span>
                                }
                            </td>
                            <td class="text-muted small">@c.FechaCreacion.ToString("dd/MM/yyyy")</td>
                            <td class="text-end">
                                @if (c.Habilitado)
                                {
                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                            data-bs-toggle="modal" data-bs-target="#modalDeshabilitar"
                                            data-id="@c.Id" data-nombre="@c.NombreCompleto">
                                        <i class="bi bi-person-x"></i> Deshabilitar
                                    </button>
                                }
                                else if (!string.IsNullOrEmpty(c.MotivoDeshabilitacion))
                                {
                                    <span class="text-muted small">
                                        <i class="bi bi-info-circle me-1"></i>@c.MotivoDeshabilitacion
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal: Deshabilitar consultor con motivo -->
<div class="modal fade" id="modalDeshabilitar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Deshabilitar">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Deshabilitar consultor</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="id" id="deshabilitarId" />
                    <p class="mb-3">
                        Vas a deshabilitar a <strong id="deshabilitarNombre"></strong>.
                        Indica el motivo (quedará registrado en los logs de auditoría).
                    </p>
                    <div class="mb-2">
                        <label class="form-label">Motivo <span class="text-danger">*</span></label>
                        <textarea name="motivo" class="form-control" rows="3" required maxlength="500"
                                  placeholder="Ej: Fin de contrato, traslado de proyecto, baja voluntaria..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-person-x me-1"></i>Confirmar deshabilitación
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const modalDeshabilitar = document.getElementById('modalDeshabilitar');
        modalDeshabilitar?.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            document.getElementById('deshabilitarId').value = button.getAttribute('data-id');
            document.getElementById('deshabilitarNombre').textContent = button.getAttribute('data-nombre');
        });
    </script>
}
