@page
@model CommanCenter.Portal.Pages.DataTeam.CrearConsultorModel
@{
    ViewData["Title"] = "Nuevo Consultor";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Nuevo Consultor</h2>
    <a asp-page="/DataTeam/Consultores" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Nombre <span class="text-danger">*</span></label>
                    <input asp-for="Input.Nombre" class="form-control" required maxlength="100" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Apellido <span class="text-danger">*</span></label>
                    <input asp-for="Input.Apellido" class="form-control" required maxlength="100" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email <span class="text-danger">*</span></label>
                    <input asp-for="Input.Email" type="email" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Teléfono</label>
                    <input asp-for="Input.Telefono" class="form-control" maxlength="20" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Cargo</label>
                    <input asp-for="Input.Cargo" class="form-control" maxlength="150" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Tecnología</label>
                    <input asp-for="Input.Tecnologia" class="form-control" maxlength="100" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Seniority</label>
                    <select asp-for="Input.NivelSeniority" class="form-select">
                        <option value="">— Seleccionar —</option>
                        <option value="Trainee">Trainee</option>
                        <option value="Junior">Junior</option>
                        <option value="Semi Senior">Semi Senior</option>
                        <option value="Senior">Senior</option>
                        <option value="Lead">Lead</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Fecha de ingreso</label>
                    <input asp-for="Input.FechaIngreso" type="date" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Fecha de nacimiento</label>
                    <input asp-for="Input.FechaNacimiento" type="date" class="form-control" />
                </div>

                <div class="col-12">
                    <label class="form-label">
                        Células <span class="text-muted small">(puede agregar una o varias)</span>
                    </label>
                    @if (Model.CelulasDisponibles.Count == 0)
                    {
                        <div class="alert alert-warning py-2 small mb-0">
                            No hay células disponibles. Primero cree una célula.
                        </div>
                    }
                    else
                    {
                        <div class="d-flex gap-2 align-items-start flex-wrap">
                            <select id="selectorCelula" class="form-select" style="max-width: 320px;">
                                <option value="">— Seleccionar célula —</option>
                                @foreach (var celula in Model.CelulasDisponibles)
                                {
                                    <option value="@celula.Id" data-color="@celula.Color">@celula.Nombre</option>
                                }
                            </select>
                            <button type="button" id="btnAgregarCelula" class="btn btn-outline-primary">
                                <i class="bi bi-plus-lg me-1"></i>Agregar
                            </button>
                        </div>
                        <div id="celulasSeleccionadas" class="d-flex flex-wrap gap-2 mt-2"></div>
                        <input type="hidden" id="celulasIdsContainer" />
                    }
                </div>

                <div class="col-12">
                    <label class="form-label">Observaciones</label>
                    <textarea asp-for="Input.Observaciones" class="form-control" rows="2"></textarea>
                </div>

                <div class="col-md-6">
                    <label class="form-label">
                        Foto de perfil <span class="text-muted small">(opcional)</span>
                    </label>
                    <input asp-for="Foto" type="file" class="form-control" accept="image/*" />
                    <span class="text-muted small">JPG, PNG, GIF o WEBP. Máximo 5 MB.</span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Crear Consultor
                </button>
                <a asp-page="/DataTeam/Consultores" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const selector = document.getElementById('selectorCelula');
            const btnAgregar = document.getElementById('btnAgregarCelula');
            const contenedor = document.getElementById('celulasSeleccionadas');
            if (!selector || !btnAgregar || !contenedor) return;

            const seleccionadas = new Set();

            function render() {
                contenedor.innerHTML = '';
                seleccionadas.forEach(id => {
                    const opt = selector.querySelector(`option[value="${id}"]`);
                    if (!opt) return;
                    const color = opt.getAttribute('data-color') || '#6c757d';

                    const tag = document.createElement('span');
                    tag.className = 'badge d-inline-flex align-items-center gap-2 p-2';
                    tag.style.background = color;
                    tag.style.fontSize = '.85rem';

                    const texto = document.createElement('span');
                    texto.textContent = opt.textContent;
                    tag.appendChild(texto);

                    const cerrar = document.createElement('button');
                    cerrar.type = 'button';
                    cerrar.className = 'btn-close btn-close-white';
                    cerrar.style.fontSize = '.6rem';
                    cerrar.setAttribute('aria-label', 'Quitar');
                    cerrar.addEventListener('click', () => {
                        seleccionadas.delete(id);
                        render();
                    });
                    tag.appendChild(cerrar);

                    const hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = 'Input.CelulasIds';
                    hidden.value = id;
                    tag.appendChild(hidden);

                    contenedor.appendChild(tag);
                });

                // Deshabilitar en el selector las ya agregadas
                Array.from(selector.options).forEach(o => {
                    if (o.value) o.disabled = seleccionadas.has(o.value);
                });
            }

            btnAgregar.addEventListener('click', () => {
                const id = selector.value;
                if (!id) return;
                seleccionadas.add(id);
                selector.value = '';
                render();
            });
        })();
    </script>
}
