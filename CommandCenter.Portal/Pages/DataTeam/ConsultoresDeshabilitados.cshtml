@page
@model CommanCenter.Portal.Pages.DataTeam.ConsultoresDeshabilitadosModel
@{
    ViewData["Title"] = "Consultores Deshabilitados";
}

@section Styles {
    <style>
        .avatar-circle {
            width: 38px; height: 38px; border-radius: 50%;
            object-fit: cover; background: #94a3b8;
            display: inline-flex; align-items: center; justify-content: center;
            color: #fff; font-weight: 700; font-size: .85rem;
        }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0">Consultores Deshabilitados</h2>
        <p class="text-muted mb-0">Ningún consultor se elimina: aquí puedes ver y reactivar a los deshabilitados.</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <span class="badge bg-secondary fs-6">@Model.Consultores.Count deshabilitados</span>
        <a asp-page="/DataTeam/Consultores" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Volver a activos
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Success))
{
    <div class="alert alert-success">@Model.Success</div>
}

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

@if (Model.Consultores.Count == 0)
{
    <div class="card shadow-sm">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-check2-circle fs-1 d-block mb-2"></i>
            No hay consultores deshabilitados.
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th></th>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Cargo</th>
                            <th>Células</th>
                            <th>Motivo</th>
                            <th>Fecha deshabilitación</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Consultores)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(c.FotoUrl))
                                    {
                                        <img src="@c.FotoUrl" alt="@c.NombreCompleto" class="avatar-circle" />
                                    }
                                    else
                                    {
                                        <span class="avatar-circle">@c.Nombre[0]@c.Apellido[0]</span>
                                    }
                                </td>
                                <td class="fw-semibold">@c.NombreCompleto</td>
                                <td class="text-muted small">@c.Email</td>
                                <td>@(c.Cargo ?? "—")</td>
                                <td>
                                    @if (c.Celulas.Count > 0)
                                    {
                                        @foreach (var cel in c.Celulas)
                                        {
                                            <span class="badge bg-info text-dark me-1 mb-1">@cel</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="small">@(c.MotivoDeshabilitacion ?? "—")</td>
                                <td class="text-muted small">
                                    @(c.FechaDeshabilitacion?.ToString("yyyy-MM-dd HH:mm") ?? "—")
                                </td>
                                <td class="text-end">
                                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                    {
                                        <form method="post" asp-page-handler="Rehabilitar" class="d-inline"
                                              onsubmit="return confirm('¿Rehabilitar a @c.NombreCompleto?');">
                                            <input type="hidden" name="id" value="@c.Id" />
                                            <button type="submit" class="btn btn-success btn-sm">
                                                <i class="bi bi-arrow-counterclockwise me-1"></i>Rehabilitar
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Sin permisos</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
