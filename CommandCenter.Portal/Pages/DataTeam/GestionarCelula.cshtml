@page
@model CommanCenter.Portal.Pages.DataTeam.GestionarCelulaModel
@{
    ViewData["Title"] = "Gestionar Célula";
    var celula = Model.Celula!;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0">
            <span class="rounded-circle d-inline-block me-1"
                  style="width:14px;height:14px;background:@celula.Color"></span>
            @celula.Nombre
        </h2>
        <p class="text-muted small mb-0">@celula.TotalMiembros miembro(s)</p>
    </div>
    <a asp-page="/DataTeam/Celulas" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.Success))
{
    <div class="alert alert-success py-2">@Model.Success</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger py-2">@Model.Error</div>
}

<div class="row g-4">
    <!-- Agregar miembro -->
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-person-plus me-1"></i>Agregar miembro
            </div>
            <div class="card-body">
                @if (!Model.ConsultoresDisponibles.Any())
                {
                    <p class="text-muted small mb-0">No hay consultores disponibles para agregar.</p>
                }
                else
                {
                    <form method="post" asp-page-handler="AgregarMiembro">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Consultor</label>
                            <select name="consultorId" class="form-select" required>
                                <option value="">— Seleccionar —</option>
                                @foreach (var c in Model.ConsultoresDisponibles)
                                {
                                    <option value="@c.Id">@c.NombreCompleto@(string.IsNullOrEmpty(c.Cargo) ? "" : $" — {c.Cargo}")</option>
                                }
                            </select>
                            <div class="form-text">Solo aparecen consultores ya creados que aún no son miembros.</div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-plus-lg me-1"></i>Agregar a la célula
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <!-- Miembros actuales -->
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-people me-1"></i>Miembros de la célula
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Consultor</th>
                            <th>Cargo</th>
                            <th class="text-end pe-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!celula.Miembros.Any())
                        {
                            <tr><td colspan="3" class="text-center text-muted py-4">Sin miembros todavía.</td></tr>
                        }
                        @foreach (var m in celula.Miembros)
                        {
                            <tr>
                                <td class="ps-3">
                                    <i class="bi bi-person-circle me-1 text-secondary"></i>@m.NombreCompleto
                                    @if (m.EsLider)
                                    {
                                        <span class="badge bg-warning text-dark ms-1"><i class="bi bi-person-badge me-1"></i>Líder</span>
                                    }
                                </td>
                                <td class="text-muted small">@(string.IsNullOrEmpty(m.Cargo) ? "—" : m.Cargo)</td>
                                <td class="text-end pe-3">
                                    @if (!m.EsLider)
                                    {
                                        <form method="post" asp-page-handler="AsignarLider" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="consultorId" value="@m.ConsultorId" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning" title="Asignar como líder">
                                                <i class="bi bi-person-badge"></i>
                                            </button>
                                        </form>
                                    }
                                    <form method="post" asp-page-handler="RemoverMiembro" class="d-inline"
                                          onsubmit="return confirm('¿Remover a @m.NombreCompleto de la célula?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="consultorId" value="@m.ConsultorId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Remover de la célula">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
