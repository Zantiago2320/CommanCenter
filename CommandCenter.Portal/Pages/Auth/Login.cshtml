@page
@model CommanCenter.Portal.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Command Center — Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #0f172a; }
        .login-card { max-width: 420px; border-radius: 16px; background: #1e293b; }
        .login-card .card-body { padding: 2.5rem; }
        .form-control { background: #0f172a; border-color: #334155; color: #f1f5f9; }
        .form-control:focus { background: #0f172a; border-color: #6366f1; color: #f1f5f9; box-shadow: 0 0 0 .2rem rgba(99,102,241,.25); }
        .form-label { color: #94a3b8; }
        .btn-login { background: #6366f1; border: none; }
        .btn-login:hover { background: #4f46e5; }
        .logo-text { font-size: 1.4rem; font-weight: 700; color: #f1f5f9; letter-spacing: .5px; }
        .logo-sub  { font-size: .85rem; color: #64748b; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100">
    <div class="login-card card shadow-lg w-100 mx-3">
        <div class="card-body">
            <div class="text-center mb-4">
                <div class="logo-text">⚡ Command Center</div>
                <div class="logo-sub">Plataforma Empresarial</div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2 small">@Model.ErrorMessage</div>
            }

            <form method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label" for="usuario">Usuario</label>
                    <input id="usuario" asp-for="Usuario" type="text" class="form-control"
                           placeholder="alexander" autocomplete="username" required />
                </div>
                <div class="mb-4">
                    <label class="form-label" for="password">Contraseña</label>
                    <input id="password" asp-for="Password" type="password" class="form-control"
                           placeholder="••••••••" autocomplete="current-password" required />
                </div>
                <button type="submit" class="btn btn-login btn-primary w-100 py-2 fw-semibold">
                    Ingresar
                </button>
            </form>
        </div>
    </div>
</body>
</html>
