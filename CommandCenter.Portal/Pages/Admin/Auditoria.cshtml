@page
@model CommanCenter.Portal.Pages.Admin.AuditoriaModel
@{
    ViewData["Title"] = "Auditoría";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0">Auditoría</h2>
        <p class="text-muted small mb-0">Quién hizo cada cambio y cuándo · @Model.Logs.Count registro(s)</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger py-2">@Model.Error</div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-sm mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Fecha (UTC)</th>
                    <th>Usuario</th>
                    <th>Módulo</th>
                    <th>Acción</th>
                    <th>Entidad</th>
                    <th>Detalle</th>
                    <th class="text-center">Estado</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Logs.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No hay registros de auditoría.</td></tr>
                }
                @foreach (var log in Model.Logs)
                {
                    <tr>
                        <td class="ps-3 small text-nowrap">@log.Fecha.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td class="small"><i class="bi bi-person-circle me-1 text-secondary"></i>@(string.IsNullOrEmpty(log.Usuario) ? "—" : log.Usuario)</td>
                        <td class="small">@log.Modulo</td>
                        <td>
                            @{
                                var color = log.Accion switch
                                {
                                    "CREATE" or "CREATE_USER" => "bg-success-subtle text-success-emphasis",
                                    "UPDATE" or "CHANGE_ROLE" or "ASSIGN_MEMBER" or "ASSIGN_LEADER" => "bg-primary-subtle text-primary-emphasis",
                                    "DELETE" or "DISABLE" or "DELETE_USER" or "REMOVE_MEMBER" => "bg-danger-subtle text-danger-emphasis",
                                    "LOGIN" => "bg-info-subtle text-info-emphasis",
                                    "LOGIN_FAIL" => "bg-warning-subtle text-warning-emphasis",
                                    _ => "bg-secondary-subtle text-secondary-emphasis"
                                };
                            }
                            <span class="badge @color">@log.Accion</span>
                        </td>
                        <td class="small">@log.Entidad @(string.IsNullOrEmpty(log.EntidadId) ? "" : $"#{log.EntidadId}")</td>
                        <td class="small text-muted">
                            @if (!string.IsNullOrEmpty(log.ValorAnterior) && !string.IsNullOrEmpty(log.ValorNuevo))
                            {
                                <span>@log.ValorAnterior → @log.ValorNuevo</span>
                            }
                            else if (!string.IsNullOrEmpty(log.ValorNuevo))
                            {
                                <span>@log.ValorNuevo</span>
                            }
                            else if (!string.IsNullOrEmpty(log.ValorAnterior))
                            {
                                <span>@log.ValorAnterior</span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (log.Exitoso)
                            {
                                <i class="bi bi-check-circle-fill text-success" title="Exitoso"></i>
                            }
                            else
                            {
                                <i class="bi bi-x-circle-fill text-danger" title="@log.Error"></i>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
