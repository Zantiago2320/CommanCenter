@page
@model CommanCenter.Portal.Pages.Admin.CorreosModel
@{
    ViewData["Title"] = "Envío de correos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Envío de correos</h2>
</div>

@if (!string.IsNullOrEmpty(Model.Success))
{
    <div class="alert alert-success">@Model.Success</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

<div class="row g-3">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">
                    <i class="bi bi-gift me-2 text-danger"></i>Recordatorio de cumpleaños
                </h5>
                <p class="text-muted flex-grow-1">
                    Envía el listado de cumpleaños del mes a los destinatarios configurados.
                    De forma automática se envía el <strong>primer día hábil del mes</strong>.
                </p>
                <form method="post" asp-page-handler="Cumpleanios">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send me-1"></i>Enviar ahora
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">
                    <i class="bi bi-bar-chart me-2 text-primary"></i>Reporte mensual
                </h5>
                <p class="text-muted flex-grow-1">
                    Envía el reporte del equipo a los destinatarios configurados.
                    De forma automática se envía el <strong>día 15 de cada mes</strong>.
                </p>
                <form method="post" asp-page-handler="Reporte">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send me-1"></i>Enviar ahora
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
