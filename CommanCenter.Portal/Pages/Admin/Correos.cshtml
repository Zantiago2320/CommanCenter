@page
@model CommanCenter.Portal.Pages.Admin.CorreosModel
@{
    ViewData["Title"] = "Envío de correos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Envío de correos</h2>
</div>

@if (!string.IsNullOrEmpty(Model.Success))
{
    <div class="alert alert-success">@Model.Success</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

<p class="text-muted">
    Antes de enviar, revise abajo a quiénes se notificará y qué datos se incluirán.
    Cada correo lleva adjunto un archivo <strong>Excel</strong> con el mismo listado.
</p>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-gift me-2 text-danger"></i>Recordatorio de cumpleaños</h5>
                <span class="badge bg-danger">@(Model.Cumpleanios?.Total ?? 0)</span>
            </div>
            <div class="card-body d-flex flex-column">
                @if (Model.Cumpleanios is null)
                {
                    <div class="alert alert-warning py-2 small mb-3">No se pudo cargar la vista previa.</div>
                }
                else
                {
                    <p class="small mb-1"><strong>Periodo:</strong> @Model.Cumpleanios.Periodo</p>
                    <p class="small mb-1">
                        <strong>Destinatarios:</strong>
                        @if (Model.Cumpleanios.Destinatarios.Count == 0)
                        {
                            <span class="text-danger">Sin destinatarios configurados</span>
                        }
                        else
                        {
                            @string.Join(", ", Model.Cumpleanios.Destinatarios)
                        }
                    </p>
                    <p class="small mb-2"><strong>Adjunto:</strong> <code>@Model.Cumpleanios.Adjunto</code></p>

                    <div class="table-responsive mb-3" style="max-height: 280px; overflow:auto;">
                        <table class="table table-sm table-striped align-middle mb-0">
                            <thead class="table-light">
                                <tr><th>Día</th><th>Nombre</th><th>Cargo</th><th>Célula</th><th>Email</th></tr>
                            </thead>
                            <tbody>
                                @if (Model.Cumpleanios.Items.Count == 0)
                                {
                                    <tr><td colspan="5" class="text-muted text-center">Nadie cumple años este mes.</td></tr>
                                }
                                else
                                {
                                    @foreach (var it in Model.Cumpleanios.Items)
                                    {
                                        <tr>
                                            <td>@it.Detalle</td>
                                            <td>@it.Nombre @it.Apellido</td>
                                            <td>@it.Cargo</td>
                                            <td>@it.Celula</td>
                                            <td class="small text-muted">@it.Email</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <form method="post" asp-page-handler="Cumpleanios" class="mt-auto">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary w-100"
                                disabled="@(Model.Cumpleanios.Destinatarios.Count == 0)">
                            <i class="bi bi-send me-1"></i>Enviar ahora (con Excel adjunto)
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-bar-chart me-2 text-primary"></i>Reporte mensual</h5>
                <span class="badge bg-primary">@(Model.Reporte?.Total ?? 0)</span>
            </div>
            <div class="card-body d-flex flex-column">
                @if (Model.Reporte is null)
                {
                    <div class="alert alert-warning py-2 small mb-3">No se pudo cargar la vista previa.</div>
                }
                else
                {
                    <p class="small mb-1"><strong>Periodo:</strong> @Model.Reporte.Periodo</p>
                    <p class="small mb-1">
                        <strong>Destinatarios:</strong>
                        @if (Model.Reporte.Destinatarios.Count == 0)
                        {
                            <span class="text-danger">Sin destinatarios configurados</span>
                        }
                        else
                        {
                            @string.Join(", ", Model.Reporte.Destinatarios)
                        }
                    </p>
                    <p class="small mb-2"><strong>Adjunto:</strong> <code>@Model.Reporte.Adjunto</code></p>

                    <div class="table-responsive mb-3" style="max-height: 280px; overflow:auto;">
                        <table class="table table-sm table-striped align-middle mb-0">
                            <thead class="table-light">
                                <tr><th>Estado</th><th>Nombre</th><th>Cargo</th><th>Célula</th><th>Email</th></tr>
                            </thead>
                            <tbody>
                                @if (Model.Reporte.Items.Count == 0)
                                {
                                    <tr><td colspan="5" class="text-muted text-center">No hay trabajadores activos.</td></tr>
                                }
                                else
                                {
                                    @foreach (var it in Model.Reporte.Items)
                                    {
                                        <tr>
                                            <td>@it.Detalle</td>
                                            <td>@it.Nombre @it.Apellido</td>
                                            <td>@it.Cargo</td>
                                            <td>@it.Celula</td>
                                            <td class="small text-muted">@it.Email</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <form method="post" asp-page-handler="Reporte" class="mt-auto">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary w-100"
                                disabled="@(Model.Reporte.Destinatarios.Count == 0)">
                            <i class="bi bi-send me-1"></i>Enviar ahora (con Excel adjunto)
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
